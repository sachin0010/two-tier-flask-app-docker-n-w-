##Network and Volume##   

docker network create two-tier -d bridge
docker network ls
docker run -d --name mysql --network two-tier -e MYSQL_ROOT_PASSWORD=root -e MYSQL_DATABASE=devops mysql

#devops db creted in mysql container
docker run -d -p 5000:5000 --network two-tier -e MYSQL_HOST=mysql -e MYSQL_USER=root -e MYSQL_PASSWORD=root -e MYSQL_DB=devops two-tier:latest
docker network inspect two-tier
###############################################################################################################################################
#docker-volume
#1Named volume
docker volume create mysql-data
cd /var/lib/docker/volumes/mysql-data/_data
docker run -d -p 5000:5000 --network two-tier -v mysql-data:/var/lib/mysql -e MYSQL_HOST=mysql -e MYSQL_USER=root -e MYSQL_PASSWORD=root -e MYSQL_DB=devops two-tier:latest
docker volume inspect mysql-data
cd /var/lib/docker/volumes/mysql-data/_data    ##data will secure here

#2Path based volume
mkdir mysql
docker run -d -p 5000:5000 --network two-tier -v /home/ubuntu/volumes/mysql:/var/lib/mysql -e MYSQL_HOST=mysql -e MYSQL_USER=root -e MYSQL_PASSWORD=root -e MYSQL_DB=devops two-tier:latest


#using docker-compose#
docker compose up
docker compose build	# fast build (use cache- sometim skips pip install)
docker compose build --no-cache #slow but clean build (  base image pull, pip install again, full fresh build)
docker compose up
docker compose down  #remove cont and n/w
docker compose down -v    #remove volume also
docker compose down --rmi all -v    #remove images also

docker system prune -a   #docker cleanup
docker system df


######Multistage byuilds####

docker compose down -v && docker system prune -a -f --volumes     #clean everything
docker system prune
docker system prune -a --volumes   #Full Deep Clean
